					ProgressBar.Main.Information.Text = tostring(percent) .. "%"
				end
			end
			updateProgress(ProgressSettings.CurrentValue or 0)

			function ProgressBarValue:Set(percent)
				percent = math.clamp(percent, 0, 100)
				updateProgress(percent)
				local Success, Response = pcall(function() ProgressSettings.Callback(percent) end)
