			local function updateProgress(percent)
				local width = math.max(ProgressBar.Main.AbsoluteSize.X * (percent / 100), 5)
				TweenService:Create(ProgressBar.Main.Progress, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(0, width, 1, 0)}):Play()
