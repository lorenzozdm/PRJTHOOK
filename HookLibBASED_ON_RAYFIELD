	TweenService:Create(Topbar.Hide, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play()
	task.wait(0.3)

	if dragBar then TweenService:Create(dragBarCosmetic, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {BackgroundTransparency = 0.7}):Play() end

	function Window.ModifyTheme(NewTheme)
		local success = pcall(ChangeTheme, NewTheme)
		if not success then
			HookLibrary:Notify({Title='Unable to Change Theme', Content='We are unable find a theme on file.', Image=4400704299})
		else
			HookLibrary:Notify({Title='Theme Changed', Content='Successfully changed theme to '..(typeof(NewTheme) == 'string' and NewTheme or 'Custom Theme')..'.', Image=4483362748})
		end
	end

	local success, result = pcall(function() createSettings(Window) end)
	if not success then warn('HookLibrary had an issue creating settings.') end

	return Window
end

local function setVisibility(visibility, notify)
	if Debounce then return end
	if visibility then
		Hidden = false
		Unhide()
	else
		Hidden = true
		Hide(notify)
	end
end

function HookLibrary:SetVisibility(visibility) setVisibility(visibility, false) end
